    id: "fb:pseudo:knapsack01",
    topicSlug: "06-dynamic-programming/01-knapsack",
    kind: "pseudocode",
    prompt:
      "Write bottom-up DP pseudocode for 0/1 KNAPSACK(w, v, n, W) where w[], v[] are length-n, W is capacity.",
    difficulty: "tricky",
    source: "final-bank",
    points: 15,
    pseudocode: {
      reference: [
        "KNAPSACK-01(w, v, n, W)",
        "  let K[0..n, 0..W] be a new table",
        "  for i = 0 to n",
        "    K[i, 0] = 0",
        "  for j = 0 to W",
        "    K[0, j] = 0",
        "  for i = 1 to n",
        "    for j = 1 to W",
        "      if w[i] > j",
        "        K[i, j] = K[i-1, j]",
        "      else",
        "        K[i, j] = max(K[i-1, j], v[i] + K[i-1, j - w[i]])",
        "  return K[n, W]",
      ],
      complexityHint: "Θ(nW) time and space — pseudo-polynomial (W can be exponential in its bit length).",
      rubric: [
        { id: "table", prompt: "Declares a 2D table K[0..n, 0..W].", keywords: ["k[", "k [", "table", "dp[", "dp [", "2d array", "matrix"], weight: 2 },
        { id: "base", prompt: "Initializes base cases (row 0 and col 0 to 0).", keywords: ["k[0", "k[i, 0]", "= 0", "k[0, j]", "dp[0]"], weight: 2 },
        { id: "skip-case", prompt: "When w[i] > j, skip item i (copy from row above).", keywords: ["w[i] > j", "k[i-1, j]", "k[i - 1, j]", "dp[i-1][j]"], weight: 2 },
        { id: "take-case", prompt: "Take-or-skip max uses v[i] + K[i-1, j - w[i]].", keywords: ["v[i] + k[i-1", "v[i] + dp[i-1", "max(", "max "], weight: 3 },
        { id: "answer", prompt: "Returns K[n, W].", keywords: ["k[n, w]", "k[n][w]", "dp[n][w]", "dp[n, w]"], weight: 1 },
      ],
    },
    explanation:
      "CLRS §16/Ch. 15 variant. The max() captures the 0/1 choice: take item i or skip it.",
  },

