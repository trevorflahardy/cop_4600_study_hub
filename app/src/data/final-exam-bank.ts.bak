/**
 * Hand-authored question bank for the COT 4400 final exam.
 *
 * Why a .ts file (not JSON):
 *   - Graph walks embed typed QuestionGraph objects, rubrics include
 *     substring arrays, and IDE autocomplete against the KbQuizQuestion type
 *     keeps new entries honest. JSON would hide these errors until runtime.
 *
 * Why separate from quizzes.json:
 *   - `scripts/build-kb.ts` regenerates quizzes.json on every `bun kb`. This
 *     module is stable — the loader merges both arrays.
 *
 * Authoring notes (mirror the real exams, Spring 2025 Exam 1 + Spring 2026 Exam 2):
 *   - Exam 1 style: 16 MCQ on asymptotic props, recursion props, log laws;
 *     then long-form recurrence solving, code → T(n), iteration+induction,
 *     pseudocode writing (factorial).
 *   - Exam 2 style: 16 MCQ on tree props, DAC, greedy, DP, memoization, Strassen;
 *     then tree traversals on a given BST, DAC max-subarray on a specific array,
 *     Fibonacci memoization pseudocode + F(5) trace, greedy job sequencing.
 *   - Predicted Final: 16 MCQ blend (with graph algos) + long-form graph trace +
 *     pseudocode writing + complexity/runtime analysis + one integrative problem.
 */

import type { KbQuizQuestion, QuestionGraph } from "@/lib/kb-loader";

