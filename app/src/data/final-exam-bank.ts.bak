    prompt: "If f(n) = 3n² + 5n log n + 7, what is the tightest asymptotic bound on f(n)?",
    difficulty: "gentle",
    source: "final-bank",
    points: 2.5,
    choices: [
      { text: "Θ(n log n)", correct: false, why: "n² dominates n log n for large n." },
      { text: "Θ(n²)",      correct: true,  why: "Drop lower-order terms; the leading term 3n² sets the bound." },
      { text: "Θ(n³)",      correct: false, why: "f is not that large — n² is the actual growth rate." },
      { text: "O(n log n)", correct: false, why: "This is a lower bound, not tight." },
    ],
    explanation: "Big-Θ captures the exact growth rate. Drop constants and lower-order terms.",
  },

  {
    id: "fb:mcq:asymptotic-2",
    topicSlug: "00-foundations/asymptotic-notation",
    kind: "mcq",
    prompt: "Which statement about O(n) and o(n) is TRUE?",
    difficulty: "firm",
    source: "final-bank",
    points: 2.5,
    choices: [
      { text: "O(n) ⊂ o(n)", correct: false, why: "Inclusion runs the other way." },
      { text: "o(n) ⊂ O(n)", correct: true,  why: "Little-o is a strictly stronger bound than big-O." },
      { text: "O(n) = o(n)", correct: false, why: "Not equal — little-o requires the ratio to go to 0." },
      { text: "Neither set contains the other.", correct: false, why: "o(n) is a proper subset of O(n)." },
    ],
    explanation: "o(n) means lim f(n)/n = 0; O(n) means the ratio is bounded. Every little-o function is also big-O.",
  },

