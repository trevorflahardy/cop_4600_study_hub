  {
    id: "fb:pseudo:dijkstra",
    topicSlug: "07-graph-algorithms/shortest-paths",
    kind: "pseudocode",
    prompt:
      "Write pseudocode for DIJKSTRA(G, w, s) assuming non-negative edge weights. Use a priority queue (min-heap).",
    difficulty: "tricky",
    source: "final-bank",
    points: 18,
    pseudocode: {
      reference: [
        "DIJKSTRA(G, w, s)",
        "  INITIALIZE-SINGLE-SOURCE(G, s)    // sets v.d = ∞, v.π = NIL, s.d = 0",
        "  S = ∅",
        "  Q = G.V                            // min-priority queue on d",
        "  while Q ≠ ∅",
        "    u = EXTRACT-MIN(Q)",
        "    S = S ∪ {u}",
        "    for each vertex v in G.Adj[u]",
        "      RELAX(u, v, w)                 // if v.d > u.d + w(u,v) update v.d, v.π, DECREASE-KEY",
      ],
      complexityHint:
        "O((V + E) log V) with a binary heap; O(V²) with an array (USF's default Θ(n²) formulation).",
      rubric: [
        { id: "init", prompt: "Initializes d[v]=∞, π[v]=NIL, d[s]=0.", keywords: ["initialize-single-source", "v.d = ∞", "d[v] = ∞", "infinity", "d[s] = 0", "s.d = 0"], weight: 2 },
        { id: "pq", prompt: "Uses a priority queue / extract-min.", keywords: ["priority queue", "min-heap", "extract-min", "extract_min", "pq", "heap"], weight: 2 },
        { id: "relax", prompt: "Relaxes edges: if v.d > u.d + w, update.", keywords: ["relax", "u.d + w", "d[u] + w", "decrease-key", "decrease_key"], weight: 3 },
        { id: "loop", prompt: "Main loop extracts one vertex per iteration until Q is empty.", keywords: ["while q", "while not q", "while |q|", "while q ≠", "while q !="], weight: 2 },
        { id: "nonneg", prompt: "(Bonus) Notes that weights must be non-negative.", keywords: ["non-negative", "nonnegative", "w >= 0", "w(u,v) ≥ 0", "no negative"], weight: 1 },
      ],
    },
    explanation:
      "Dijkstra is greedy: the extracted min is guaranteed to have its final shortest-path distance set.",
  },

