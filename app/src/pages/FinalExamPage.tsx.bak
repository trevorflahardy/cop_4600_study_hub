import { useMemo, useState, useEffect } from "react";
import { Link, useSearch, useNavigate } from "@tanstack/react-router";
import { motion, AnimatePresence } from "motion/react";
import { ArrowLeft, ArrowRight, Clock, Timer, Trophy, CheckCircle2, GitBranch, Code2, Gauge, ListChecks, Sparkles } from "lucide-react";
import { Frame, Button, Chip, Eyebrow, MiniLabel, Highlighter, StatCard, PipRow, type PipState } from "@/components/notebook";
import { allQuizzes, quizzesFromBank, type KbQuizQuestion } from "@/lib/kb-loader";
import { recordAnswer } from "@/lib/mastery";
import { GraphWalkQuestion } from "@/features/practice/GraphWalkQuestion";
import { PseudocodeQuestion } from "@/features/practice/PseudocodeQuestion";
import { RuntimeQuestion } from "@/features/practice/RuntimeQuestion";
import { useSettings } from "@/stores/settings";

type Mode = "hub" | "graph" | "pseudo" | "runtime" | "simulator" | "mcq";

/**
 * Final Exam Prep hub.
 *
 * Design goals (from README "How Trev prefers to learn"):
 *  - Coherent flow: mode selection → focused drill → debrief → next CTA.
 *  - Notebook aesthetic (Frames, Eyebrows, Highlighter, JetBrains Mono).
 *  - No dead ends: every finished drill points at what to do next.
 *  - Reuse existing question types where possible (MCQ bank = same type the
 *    rest of the app renders; we just filter to the final-bank source).
 *  - Real exam style, modeled on Exam 1 + Exam 2:
 *        16 MCQ (40 pts) + 3-4 long-form (60 pts) = 100 pts.
 */
export function FinalExamPage() {
  const search = useSearch({ strict: false }) as { mode?: Mode };
  const navigate = useNavigate();
  const [mode, setMode] = useState<Mode>(search.mode ?? "hub");

  useEffect(() => {
    if (search.mode && search.mode !== mode) setMode(search.mode);
  }, [search.mode, mode]);

  function go(m: Mode) {
    setMode(m);
    navigate({ to: "/final", search: { mode: m } });
  }

  const bank = useMemo(() => quizzesFromBank(), []);
  const graphWalks = bank.filter((q) => q.kind === "graph-walk");
  const pseudocodes = bank.filter((q) => q.kind === "pseudocode");
  const runtimes = bank.filter((q) => q.kind === "runtime");
  const mcqBank = bank.filter((q) => q.kind === "mcq");

  if (mode === "hub") {
    return <FinalHub
      counts={{ graph: graphWalks.length, pseudo: pseudocodes.length, runtime: runtimes.length, mcq: mcqBank.length }}
      onGo={go}
    />;
  }
  if (mode === "graph") return <DrillRunner title="Graph walkthroughs" questions={graphWalks} onDone={() => go("hub")} />;
  if (mode === "pseudo") return <DrillRunner title="Pseudocode drills" questions={pseudocodes} onDone={() => go("hub")} />;
  if (mode === "runtime") return <DrillRunner title="Runtime drills" questions={runtimes} onDone={() => go("hub")} />;
  if (mode === "mcq") return <DrillRunner title="MCQ practice · exam-style" questions={mcqBank} onDone={() => go("hub")} />;
  if (mode === "simulator") return <Simulator onDone={() => go("hub")} />;
  return null;
}

// ─── Hub ─────────────────────────────────────────────────────────────────────

function FinalHub({ counts, onGo }: {
  counts: { graph: number; pseudo: number; runtime: number; mcq: number };
  onGo: (m: Mode) => void;
}) {
  const { ollamaEnabled } = useSettings();

  return (
    <div className="flex flex-col gap-6">
      <Frame variant="wobble" shadow="card" className="!p-8">
        <Eyebrow>final exam prep · COT 4400</Eyebrow>
        <h1 className="mt-3">
          Dry-run the final with <Highlighter>real exam shape</Highlighter>.
        </h1>
        <p className="mt-3 serif italic text-[var(--ink-2)] max-w-[62ch]">
          Built from your actual Exam 1 and Exam 2 patterns: 16 MCQ for 40 pts,
          then long-form work — pseudocode, runtime analysis, graph traces.
          Pick a drill, or run the full simulator end-to-end.
        </p>
        <div className="mt-4 flex gap-2 flex-wrap">
          <Chip tone="sky">16 MCQ + 4 long-form</Chip>
          <Chip tone="hl">~75 min simulator</Chip>
          <Chip tone={ollamaEnabled ? "mint" : "soft"}>
            Ollama {ollamaEnabled ? "on" : "off"} · pseudocode grading
          </Chip>
        </div>
      </Frame>

      <div className="grid gap-4" style={{ gridTemplateColumns: "repeat(auto-fit, minmax(240px, 1fr))" }}>
        <DrillTile
          icon={<GitBranch size={20} />}
          kicker="GRAPH"
          title="Walk through graph algorithms"
          blurb="Click nodes in BFS / DFS / Dijkstra / Prim order. Kruskal: click edges."
          count={counts.graph}
          onClick={() => onGo("graph")}
        />
        <DrillTile
          icon={<Code2 size={20} />}
          kicker="PSEUDOCODE"
          title="Write pseudocode · Ollama grades"
          blurb="Offline rubric runs always; Ollama streams tutor feedback if enabled."
          count={counts.pseudo}
          onClick={() => onGo("pseudo")}
        />
        <DrillTile
          icon={<Gauge size={20} />}
          kicker="RUNTIME"
          title="Best / avg / worst / space"
          blurb="For every algorithm in the course. Asymptotic notation, partial credit."
          count={counts.runtime}
          onClick={() => onGo("runtime")}
        />
        <DrillTile
          icon={<ListChecks size={20} />}
          kicker="MCQ"
          title="Exam-style MCQs"
          blurb="Short definitional traps, asymptotic comparisons, graph / DP / greedy."
          count={counts.mcq}
          onClick={() => onGo("mcq")}
        />
      </div>

      <Frame>
        <div className="flex items-baseline gap-3 flex-wrap">
          <Eyebrow>full simulator</Eyebrow>
          <span className="flex-1" />
          <MiniLabel>pace like the real thing</MiniLabel>
        </div>
        <div className="mt-2 flex items-baseline gap-6 flex-wrap">
          <div>
            <div className="display text-4xl">100</div>
            <div className="mini-label">total points</div>
          </div>
          <div>
            <div className="display text-4xl">16</div>
            <div className="mini-label">MCQ · 40 pts</div>
          </div>
          <div>
            <div className="display text-4xl">4</div>
            <div className="mini-label">long-form · ~15 pts each</div>
          </div>
          <div>
            <div className="display text-4xl">75</div>
            <div className="mini-label">minutes budgeted</div>
          </div>
          <span className="flex-1" />
          <Button variant="pop" size="big" onClick={() => onGo("simulator")}>
            <Timer size={18} /> Start simulator
          </Button>
        </div>
        <p className="serif italic text-[14px] text-[var(--ink-2)] mt-3 max-w-[62ch]">
          Runs a randomized sample that mirrors the real exam structure (16 MCQ
          then 4 long-form covering graph trace, pseudocode, runtime analysis,
          and one integrative problem). Timer is visible but doesn't lock you
          out — you can keep going.
        </p>
      </Frame>

      <Frame variant="soft">
        <Eyebrow>what the final will probably look like</Eyebrow>
        <div className="grid gap-4 mt-3" style={{ gridTemplateColumns: "repeat(auto-fit, minmax(260px, 1fr))" }}>
          <div>
            <MiniLabel>part 1 · 16 MCQ · 40 pts</MiniLabel>
            <p className="serif text-[14px] mt-2">
              Mix of asymptotic properties, traversal order, DP vs DAC vs greedy,
              pseudocode tracing, and a fresh slice of graph-algorithm traps
              (BFS invariants, MST properties, topo sort prerequisites).
            </p>
          </div>
          <div>
            <MiniLabel>part 2 · long-form · ~60 pts</MiniLabel>
            <ul className="serif text-[14px] mt-2 list-disc pl-5 space-y-1">
              <li>Trace one graph algorithm (BFS, DFS, Dijkstra, Prim, or Kruskal).</li>
              <li>Write pseudocode for a named algorithm.</li>
              <li>Analyze the runtime of given code (sum a loop-count expression).</li>
              <li>An integrative problem spanning two chapters.</li>
